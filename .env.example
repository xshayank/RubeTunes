API_ID=api_id
API_HASH=api_hash
BOT_TOKEN=bot_token
RUBIKA_SESSION=rubsession
RUBIKA_PHONE=09xxxxxxxxx
# Comma-separated Rubika object GUIDs that have admin privileges (e.g. from a private chat)
ADMIN_GUIDS=

# --- Spotify downloading ---
# Anonymous Spotify token is obtained automatically via built-in TOTP — no account needed.
# Optionally set client-credentials as a fallback if the anonymous token fails.
# Create a free app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Deezer (lossless FLAC download) ---
# Deezer account ARL cookie — enables lossless FLAC downloads.
# Obtain from your browser's cookies after logging in to deezer.com.
# Leave blank to fall back to Qobuz or YouTube Music.
DEEZER_ARL=

# --- Qobuz ---
# Qobuz credentials are auto-scraped from open.qobuz.com and cached locally.
# No account, email, password, or API key is needed.

# --- Tidal (metadata resolution only) ---
# Client/OAuth token for Tidal track metadata and ISRC lookup.
# Tidal tracks are downloaded via the ISRC resolution chain (Qobuz/Deezer/YouTube Music).
TIDAL_TOKEN=

# --- Batch download concurrency ---
# Number of tracks downloaded in parallel for albums/playlists (default 3, range 1–6).
BATCH_CONCURRENCY=3

# --- Provider circuit breaker ---
# Open the circuit after CIRCUIT_FAIL_THRESHOLD consecutive failures within
# CIRCUIT_FAIL_WINDOW_SEC seconds.  Keep it open for CIRCUIT_OPEN_DURATION_SEC seconds.
CIRCUIT_FAIL_THRESHOLD=3
CIRCUIT_FAIL_WINDOW_SEC=300
CIRCUIT_OPEN_DURATION_SEC=600

# --- Logging (A5) ---
# Set LOG_FORMAT=json to emit structured JSON log lines (requires python-json-logger).
# Default is human-readable text.
LOG_FORMAT=text

# --- Prometheus metrics (A6) ---
# Serve a /metrics endpoint on this port.  Set to 0 to disable.
METRICS_PORT=9090

# --- Sentry error reporting (A7) ---
# Set to your Sentry DSN to enable error reporting.  Leave blank to disable.
SENTRY_DSN=

# --- Graceful shutdown (A8) ---
# Seconds to wait for in-flight downloads to finish before hard-killing.
SHUTDOWN_TIMEOUT_SEC=30

# --- Per-user rate limiting (D3) ---
# Maximum tracks a non-admin user can request per rolling hour.
USER_TRACKS_PER_HOUR=100

# --- Disk space guard (D2) ---
# Reject a batch if free disk space is less than MIN_FREE_SPACE_MULTIPLIER × estimate.
MIN_FREE_SPACE_MB=500
MIN_FREE_SPACE_MULTIPLIER=2.0
HEURISTIC_MB_PER_TRACK=30
