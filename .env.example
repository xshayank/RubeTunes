API_ID=api_id
API_HASH=api_hash
BOT_TOKEN=bot_token
RUBIKA_SESSION=rubsession
RUBIKA_PHONE=09xxxxxxxxx
# Comma-separated Rubika object GUIDs that have admin privileges (e.g. from a private chat)
ADMIN_GUIDS=

# --- Spotify downloading (SpotiFLAC approach) ---
# Base-32 TOTP secret for anonymous Spotify token (no Spotify account needed).
# Leave blank to use client-credentials fallback below.
SPOTIFY_TOTP_SECRET=

# Spotify app credentials — fallback if anonymous token fails.
# Create a free app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Deezer account ARL cookie — enables lossless FLAC downloads.
# Obtain from your browser's cookies after logging in to deezer.com.
# Leave blank to fall back to YouTube Music (MP3 320 kbps).
DEEZER_ARL=
